{
  "manifest_version": 3,
  "name": "Beyond Markdown",
  "short_name": "Beyond MD",
  "version": "1.1.0",
  "description": "Export D&D Beyond content as Markdown",
  "author": "Alvaro Cavalcanti",
  "homepage_url": "https://github.com/AlvaroCavalcanti/beyond-markdown",
  "minimum_chrome_version": "109",
  "browser_specific_settings": {
    "gecko": {
      "id": "beyond-markdown@memorablenaton.es",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "downloads"
  ],
  "host_permissions": [
    "https://www.dndbeyond.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Beyond Markdown",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.dndbeyond.com/*"],
      "js": ["content/content-script.ts"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}

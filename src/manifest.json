{
  "manifest_version": 3,
  "name": "Beyond Markdown",
  "version": "1.0.0",
  "description": "Export D&D Beyond content as Markdown",
  "permissions": [
    "storage",
    "downloads",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.dndbeyond.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Export to Markdown",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.dndbeyond.com/*"],
      "js": ["content/content-script.js"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}

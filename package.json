{
  "name": "beyond-markdown",
  "version": "1.0.0",
  "description": "A browser extension for you to export your D&amp;D Beyond content as Markdown.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:firefox": "TARGET_BROWSER=firefox vite",
    "build": "tsc && vite build",
    "build:firefox": "tsc && TARGET_BROWSER=firefox vite build && node scripts/firefox-manifest.js",
    "lint": "eslint src --ext .ts",
    "release:chrome": "npm run build && node scripts/release.js chrome",
    "release:firefox": "npm run build:firefox && node scripts/release.js firefox",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/chrome": "^0.1.32",
    "@types/webextension-polyfill": "^0.12.4",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli": "^0.47.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-web-extension": "^4.5.0",
    "webextension-polyfill": "^0.12.0"
  },
  "dependencies": {
    "@types/turndown": "^5.0.6",
    "turndown": "^7.2.2"
  },
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.md": "markdownlint --fix"
  }
}
